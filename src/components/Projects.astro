---
import Button from "@/src/components/ui/Button.astro";
import Tag from "@/src/components/ui/Tag.astro";
import { Image } from "astro:assets";
import MakefyProjectImg from "@/src/assets/makefy.jpeg";
import MakefyProjectImg2 from "@/src/assets/makefy2.jpeg";
import BlogProjectImg from "@/src/assets/blog.jpeg";
import AlexGitProjectImg from "@/src/assets/alexgit.png";
import VueStitchesProjectImg from "@/src/assets/vue-stitches.webp";
import ByteBuzzImg1 from "@/src/assets/bytebuzz-1.png";
import ByteBuzzImg3 from "@/src/assets/bytebuzz-3.png";
import ByteBuzzImg4 from "@/src/assets/bytebuzz-4.png";
import ByteBuzzImg5 from "@/src/assets/bytebuzz-5.png";
import ByteBuzzImg6 from "@/src/assets/bytebuzz-6.png";
import AiAnalyzerImg1 from "@/src/assets/ai-analyzer.png";
import AiAnalyzerImg2 from "@/src/assets/ai-analyzer-2.png";
import { Icon } from "astro-icon/components";

interface Project {
  title: string;
  description: string;
  images: ImageMetadata[];
  tags: string[];
  liveUrl?: string;
  githubUrl: string;
  status: "completed" | "in-progress";
  featured?: boolean;
}

const projects: Project[] = [
  {
    title: "ByteBuzz",
    description:
      "A full-stack social platform for developers featuring rich-text and code-snippet authoring powered by Lexical and Monaco, real-time feeds backed by Supabase, type-safe APIs with Zod and TanStack Query, and Clerk-based authentication with RLS policies.",
    images: [ByteBuzzImg1, ByteBuzzImg3, ByteBuzzImg4, ByteBuzzImg5, ByteBuzzImg6],
    tags: [
      "Next.js 16",
      "React 19",
      "TanStack Query",
      "Supabase",
      "Lexical",
      "Zod",
      "Clerk",
      "Tailwind CSS 4",
    ],
    liveUrl: "https://bytebuzz.dev",
    githubUrl: "https://github.com/dartilesm/bytebuzz",
    status: "in-progress",
    featured: true,
  },
  {
    title: "AI Skill Optimizer",
    description:
      "Analyzes repositories for AI tool compatibility and rule coverage, highlighting areas for improvement with actionable tips.",
    images: [AiAnalyzerImg1, AiAnalyzerImg2],
    tags: ["Next.js 16", "TypeScript", "Zod", "Zustand", "Shadcn", "GitHub API"],
    githubUrl: "https://github.com/dartilesm/ai-skill-optimizer",
    status: "in-progress",
  },
  {
    title: "Makefy",
    description:
      "A monorepo project of a collection of AI tools to accelerate your work. Including a chat-with-pdf, text tools like Q&A generator, Podcast script generator, and more.",
    images: [MakefyProjectImg, MakefyProjectImg2],
    tags: ["Next.js", "Supabase", "Shadcn", "Vercel AI SDK"],
    liveUrl: "https://makefy.app",
    githubUrl: "https://github.com/dartilesm/makefy",
    status: "in-progress",
  },
  {
    title: "AlexGit — Virtual Git Assistant",
    description:
      "An AI virtual assistant designed to help with the day-to-day tasks of Git version control system.",
    images: [AlexGitProjectImg],
    tags: ["CohereAI", "Node.js"],
    githubUrl: "https://github.com/dartilesm/alexgit",
    status: "completed",
  },
  {
    title: "vue-stitches",
    description:
      "A small package that helps to better use Stitches in Vue projects. Stitches only has an adapted version of React, so I'm using the core version to make this package.",
    images: [VueStitchesProjectImg],
    tags: ["Vue", "Javascript"],
    githubUrl: "https://github.com/dartilesm/vue-stitches",
    status: "completed",
  },
  {
    title: "DartilesDev",
    description:
      "A personal blog platform built to share technical knowledge and insights about web development, focusing on modern frontend technologies and best practices.",
    images: [BlogProjectImg],
    tags: ["Svelte"],
    liveUrl: "https://dartiles.dev",
    githubUrl: "https://github.com/dartilesm/dartiles.dev",
    status: "completed"
  },
];
---

<section class='py-16'>
  <p class='text-xs font-medium tracking-widest uppercase text-text-muted mb-3'>Work</p>
  <h2 class='font-heading font-bold text-3xl text-text-primary mb-8'>Featured Projects</h2>

  <div class='grid grid-cols-1 gap-3 md:grid-cols-3'>
    {
      projects.map((project, index) => {
        const num = String(index + 1).padStart(2, "0");
        return (
          <div
            class:list={[
              "project-card group relative",
              project.featured ? "md:col-span-3" : "",
            ]}
          >
            {/* Dashed border sides */}
            <div class='cb cb-top' aria-hidden='true' />
            <div class='cb cb-right' aria-hidden='true' />
            <div class='cb cb-bottom' aria-hidden='true' />
            <div class='cb cb-left' aria-hidden='true' />
            {/* Corner brackets */}
            <div class='cc cc-tl' aria-hidden='true' />
            <div class='cc cc-tr' aria-hidden='true' />
            <div class='cc cc-bl' aria-hidden='true' />
            <div class='cc cc-br' aria-hidden='true' />
            {/* Project number watermark */}
            <span class='proj-num' aria-hidden='true'>{num}</span>

            {/* ── FEATURED CARD (ByteBuzz) ── */}
            {project.featured && (
              <div class='relative h-[480px] overflow-hidden'>
                {/* Slideshow images */}
                <div
                  data-slideshow
                  data-slide-count={project.images.length}
                  class='absolute inset-0'
                >
                  {project.images.map((img, i) => (
                    <Image
                      src={img}
                      alt={`${project.title} screenshot ${i + 1}`}
                      data-slide-img
                      class:list={[
                        "slideshow-img w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]",
                        { "opacity-100": i === 0, "opacity-0": i !== 0 },
                      ]}
                    />
                  ))}
                </div>
                {/* Gradient overlay */}
                <div
                  class='absolute inset-0 pointer-events-none'
                  style='background: linear-gradient(to top, #000 0%, #000 18%, rgba(0,0,0,0.45) 55%, transparent 100%)'
                />
                {/* Status badge */}
                {project.status === "in-progress" && (
                  <div class='absolute top-4 left-4 z-20 flex items-center gap-1.5 bg-yellow-500/15 border border-yellow-500/30 text-yellow-400 text-xs px-2.5 py-1 rounded-full font-mono'>
                    <span class='relative flex h-1.5 w-1.5'>
                      <span class='absolute inline-flex h-full w-full rounded-full opacity-75 bg-yellow-400 animate-ping' />
                      <span class='relative inline-flex rounded-full h-1.5 w-1.5 bg-yellow-500' />
                    </span>
                    In Progress
                  </div>
                )}
                {/* Content */}
                <div class='absolute bottom-0 left-0 p-6 z-10 md:max-w-[60%]'>
                  <h3 class='font-heading font-bold text-2xl text-white mb-2'>{project.title}</h3>
                  <p class='text-white/70 text-sm leading-relaxed mb-3'>{project.description}</p>
                  <div class='flex flex-wrap gap-1.5 mb-4'>
                    {project.tags.map((tag) => (
                      <Tag class='bg-white/10 text-white border-white/15 font-mono'>{tag}</Tag>
                    ))}
                  </div>
                  <div class='flex items-center gap-3 flex-wrap'>
                    {project.liveUrl && (
                      <Button
                        href={project.liveUrl}
                        variant='primary'
                        target='_blank'
                        rel='noopener noreferrer'
                        class='group/btn flex-shrink-0'
                      >
                        Project
                        <Icon
                          name='external-link'
                          slot='icon'
                          class='group-hover/btn:translate-x-1 transition-transform duration-200'
                        />
                      </Button>
                    )}
                    <Button
                      href={project.githubUrl}
                      variant='ghost'
                      target='_blank'
                      rel='noopener noreferrer'
                      class='text-white/80 hover:text-white group/btn flex-shrink-0'
                    >
                      Code
                      <Icon
                        name='external-link'
                        slot='icon'
                        class='group-hover/btn:translate-x-1 transition-transform duration-200'
                      />
                    </Button>
                    {project.images.length > 1 && (
                      <div class='flex gap-1.5 ml-3' data-slideshow-dots>
                        {project.images.map((_, i) => (
                          <button
                            data-slide-dot={i}
                            class:list={[
                              "w-1.5 h-1.5 rounded-full transition-colors duration-300 cursor-pointer",
                              { "bg-white": i === 0, "bg-white/30 hover:bg-white/60": i !== 0 },
                            ]}
                            aria-label={`Go to image ${i + 1}`}
                          />
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </div>
            )}

            {/* ── STANDARD CARD ── */}
            {!project.featured && (
              <div class='flex flex-col h-full'>
                {/* Image area */}
                <div class='relative overflow-hidden' style='aspect-ratio: 16/10;'>
                  <div
                    data-slideshow
                    data-slide-count={project.images.length}
                    class='absolute inset-0'
                  >
                    {project.images.map((img, i) => (
                      <Image
                        src={img}
                        alt={`${project.title} screenshot ${i + 1}`}
                        data-slide-img
                        class:list={[
                          "slideshow-img w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]",
                          { "opacity-100": i === 0, "opacity-0": i !== 0 },
                        ]}
                      />
                    ))}
                  </div>
                  {/* Bottom fade into page bg */}
                  <div
                    class='absolute bottom-0 inset-x-0 h-14 pointer-events-none'
                    style='background: linear-gradient(to top, var(--color-bg) 0%, transparent 100%)'
                  />
                  {/* Status badge */}
                  {project.status === "in-progress" && (
                    <div class='absolute top-3 left-3 z-10 flex items-center gap-1.5 bg-yellow-500/15 border border-yellow-500/30 text-yellow-400 text-xs px-2 py-0.5 rounded-full font-mono'>
                      <span class='relative flex h-1.5 w-1.5'>
                        <span class='absolute inline-flex h-full w-full rounded-full opacity-75 bg-yellow-400 animate-ping' />
                        <span class='relative inline-flex rounded-full h-1.5 w-1.5 bg-yellow-500' />
                      </span>
                      In Progress
                    </div>
                  )}
                  {/* Slideshow dots */}
                  {project.images.length > 1 && (
                    <div
                      class='absolute bottom-2 right-3 flex gap-1.5 z-10'
                      data-slideshow-dots
                    >
                      {project.images.map((_, i) => (
                        <button
                          data-slide-dot={i}
                          class:list={[
                            "w-1.5 h-1.5 rounded-full transition-colors duration-300 cursor-pointer shadow-sm",
                            { "bg-white": i === 0, "bg-white/40 hover:bg-white/60": i !== 0 },
                          ]}
                          aria-label={`Go to image ${i + 1}`}
                        />
                      ))}
                    </div>
                  )}
                </div>
                {/* Content */}
                <div class='p-5 flex flex-col gap-2 flex-1'>
                  <h3 class='font-heading font-semibold text-base text-text-primary leading-tight'>
                    {project.title}
                  </h3>
                  <div class='flex-1'>
                    <p class='text-text-secondary text-sm leading-relaxed'>{project.description}</p>
                    <div class='flex flex-wrap gap-1.5 mt-1'>
                      {project.tags.map((tag) => (
                        <Tag>{tag}</Tag>
                      ))}
                    </div>
                  </div>
                  <div class='flex gap-3 flex-wrap mt-2'>
                    {project.liveUrl && (
                      <Button
                        href={project.liveUrl}
                        variant='primary'
                        target='_blank'
                        rel='noopener noreferrer'
                        class='group/btn flex-shrink-0'
                      >
                        Project
                        <Icon
                          name='external-link'
                          slot='icon'
                          class='group-hover/btn:translate-x-1 transition-transform duration-200'
                        />
                      </Button>
                    )}
                    <Button
                      href={project.githubUrl}
                      variant={project.liveUrl ? "ghost" : "primary"}
                      target='_blank'
                      rel='noopener noreferrer'
                      class='group/btn flex-shrink-0'
                    >
                      Code
                      <Icon
                        name='external-link'
                        slot='icon'
                        class='group-hover/btn:translate-x-1 transition-transform duration-200'
                      />
                    </Button>
                  </div>
                </div>
              </div>
            )}
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .slideshow-img {
    position: absolute;
    inset: 0;
    transition: opacity 700ms ease-in-out;
  }

  /* ── Dashed border sides ──────────────────────────── */
  .cb {
    position: absolute;
    pointer-events: none;
    z-index: 1;
  }
  .cb-top {
    top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, rgba(99, 102, 241, 0.25) 50%, transparent 50%);
    background-size: 8px 1px;
  }
  .cb-right {
    top: 0; right: 0; bottom: 0; width: 1px;
    background: linear-gradient(180deg, rgba(99, 102, 241, 0.25) 50%, transparent 50%);
    background-size: 1px 8px;
  }
  .cb-bottom {
    bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, rgba(99, 102, 241, 0.25) 50%, transparent 50%);
    background-size: 8px 1px;
  }
  .cb-left {
    top: 0; left: 0; bottom: 0; width: 1px;
    background: linear-gradient(180deg, rgba(99, 102, 241, 0.25) 50%, transparent 50%);
    background-size: 1px 8px;
  }

  .project-card:hover .cb-top,
  .project-card:hover .cb-bottom {
    background: linear-gradient(90deg, rgba(99, 102, 241, 0.55) 50%, transparent 50%);
    background-size: 8px 1px;
  }
  .project-card:hover .cb-right,
  .project-card:hover .cb-left {
    background: linear-gradient(180deg, rgba(99, 102, 241, 0.55) 50%, transparent 50%);
    background-size: 1px 8px;
  }

  /* ── Corner brackets ──────────────────────────────── */
  .cc {
    position: absolute;
    width: 12px;
    height: 12px;
    pointer-events: none;
    z-index: 2;
  }
  .cc::before,
  .cc::after {
    content: '';
    position: absolute;
    background: rgba(99, 102, 241, 0.45);
    transition: background 0.3s ease;
  }
  .project-card:hover .cc::before,
  .project-card:hover .cc::after {
    background: rgba(99, 102, 241, 0.9);
  }

  .cc-tl { top: -1px; left: -1px; }
  .cc-tl::before { width: 100%; height: 2px; top: 0; left: 0; }
  .cc-tl::after  { width: 2px; height: 100%; top: 0; left: 0; }

  .cc-tr { top: -1px; right: -1px; }
  .cc-tr::before { width: 100%; height: 2px; top: 0; right: 0; }
  .cc-tr::after  { width: 2px; height: 100%; top: 0; right: 0; }

  .cc-bl { bottom: -1px; left: -1px; }
  .cc-bl::before { width: 100%; height: 2px; bottom: 0; left: 0; }
  .cc-bl::after  { width: 2px; height: 100%; bottom: 0; left: 0; }

  .cc-br { bottom: -1px; right: -1px; }
  .cc-br::before { width: 100%; height: 2px; bottom: 0; right: 0; }
  .cc-br::after  { width: 2px; height: 100%; bottom: 0; right: 0; }

  /* ── Project number watermark ─────────────────────── */
  .proj-num {
    position: absolute;
    top: 6px;
    right: 10px;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    color: rgba(99, 102, 241, 0.07);
    pointer-events: none;
    z-index: 2;
    transition: color 0.3s ease;
    user-select: none;
  }
  .project-card:hover .proj-num {
    color: rgba(99, 102, 241, 0.14);
  }
</style>

<script>
  function initSlideshows() {
    document.querySelectorAll<HTMLElement>("[data-slideshow]").forEach(function (container) {
      const count = parseInt(container.dataset.slideCount || "0", 10);
      if (count <= 1) return;

      const images = container.querySelectorAll<HTMLElement>("[data-slide-img]");
      const dotsContainer =
        container.querySelector("[data-slideshow-dots]") ||
        container.closest("div[class*='project-card']")?.querySelector("[data-slideshow-dots]");
      const dots = dotsContainer
        ? dotsContainer.querySelectorAll<HTMLButtonElement>("[data-slide-dot]")
        : [];

      let active = 0;
      let paused = false;

      function goTo(index: number) {
        images.forEach(function (img, i) {
          img.classList.toggle("opacity-100", i === index);
          img.classList.toggle("opacity-0", i !== index);
        });
        dots.forEach(function (dot, i) {
          dot.classList.toggle("bg-white", i === index);
          dot.classList.toggle("bg-white/30", i !== index);
          dot.classList.toggle("hover:bg-white/60", i !== index);
        });
        active = index;
      }

      const intervalId = setInterval(function () {
        if (paused) return;
        goTo((active + 1) % count);
      }, 4000);

      dots.forEach(function (dot) {
        dot.addEventListener("click", function () {
          const targetIndex = parseInt(dot.dataset.slideDot || "0", 10);
          if (targetIndex === active) {
            paused = !paused;
            return;
          }
          paused = true;
          goTo(targetIndex);
        });
      });

      container.dataset.intervalId = String(intervalId);
    });
  }

  initSlideshows();
</script>
