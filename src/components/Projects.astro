---
import Card from "@/src/components/ui/Card.astro";
import Button from "@/src/components/ui/Button.astro";
import Tag from "@/src/components/ui/Tag.astro";
import { Image } from "astro:assets";
import MakefyProjectImg from "@/src/assets/makefy.jpeg";
import MakefyProjectImg2 from "@/src/assets/makefy2.jpeg";
import BlogProjectImg from "@/src/assets/blog.jpeg";
import AlexGitProjectImg from "@/src/assets/alexgit.png";
import VueStitchesProjectImg from "@/src/assets/vue-stitches.webp";
import ByteBuzzImg1 from "@/src/assets/bytebuzz-1.png";
import ByteBuzzImg2 from "@/src/assets/bytebuzz-2.png";
import ByteBuzzImg3 from "@/src/assets/bytebuzz-3.png";
import ByteBuzzImg4 from "@/src/assets/bytebuzz-4.png";
import ByteBuzzImg5 from "@/src/assets/bytebuzz-5.png";
import ByteBuzzImg6 from "@/src/assets/bytebuzz-6.png";
import AiAnalyzerImg1 from "@/src/assets/ai-analyzer.png";
import AiAnalyzerImg2 from "@/src/assets/ai-analyzer-2.png";
import { Icon } from "astro-icon/components";

interface Project {
  title: string;
  description: string;
  images: ImageMetadata[];
  tags: string[];
  liveUrl?: string;
  githubUrl: string;
  status: "completed" | "in-progress";
  featured?: boolean;
}

const projects: Project[] = [
  {
    title: "ByteBuzz",
    description:
      "A modern social platform for developers and tech enthusiasts to share code snippets, tech news, programming memes, and connect with like-minded peers.",
    images: [ByteBuzzImg1, ByteBuzzImg2, ByteBuzzImg3, ByteBuzzImg4, ByteBuzzImg5, ByteBuzzImg6],
    tags: ["Next.js", "React", "Supabase", "TypeScript", "Clerk"],
    liveUrl: "https://bytebuzz.dev",
    githubUrl: "https://github.com/dartilesm/bytebuzz",
    status: "in-progress",
    featured: true,
  },
  {
    title: "AI Skill Optimizer",
    description:
      "A developer tool that analyzes project file structures and reports which AI model skills, rules, and agent instructions are discoverable, missing, or misconfigured across tools like Claude Code, Cursor, and Gemini CLI.",
    images: [AiAnalyzerImg1, AiAnalyzerImg2],
    tags: ["Next.js", "TypeScript", "Zustand", "Shadcn"],
    githubUrl: "https://github.com/dartilesm/ai-skill-optimizer",
    status: "in-progress",
  },
  {
    title: "Makefy",
    description:
      "A monorepo project of a collection of AI tools to accelerate your work. Including a chat-with-pdf, text tools like Q&A generator, Podcast script generator, and more.",
    images: [MakefyProjectImg, MakefyProjectImg2],
    tags: ["Next.js", "Supabase", "Shadcn", "AI Vercel SDK"],
    liveUrl: "https://makefy.app",
    githubUrl: "https://github.com/dartilesm/makefy",
    status: "in-progress",
  },
  {
    title: "AlexGit - A Virtual Git Assistant",
    description:
      "Alexgit is an AI virtual assistant designed to help with the day-to-day tasks of Git version control system.",
    images: [AlexGitProjectImg],
    tags: ["CohereAI", "Node.js"],
    githubUrl: "https://github.com/dartilesm/alexgit",
    status: "completed",
  },
  {
    title: "vue-stitches",
    description:
      "It is a small package that helps to better use Stitches in Vue projects. Stitches (at the time I'm writing this) only has an adapted version of React, so I'm using the core version to make this package.",
    images: [VueStitchesProjectImg],
    tags: ["Vue", "Javascript"],
    githubUrl: "https://github.com/dartilesm/vue-stitches",
    status: "completed",
  },
  {
    title: "DartilesDev",
    description:
      "A personal blog platform built to share technical knowledge and insights about web development, focusing on modern frontend technologies and best practices.",
    images: [BlogProjectImg],
    tags: ["Svelte"],
    liveUrl: "https://dartiles.dev",
    githubUrl: "https://github.com/dartilesm/dartiles.dev",
    status: "completed",
  },
];
---

<section class='py-16'>
  <h2 class='text-2xl font-bold mb-8'>Featured Projects</h2>
  <div class='grid grid-cols-1 gap-8 md:grid-cols-3'>
    {
      projects.map((project) => (
        <Card
          variant={project.featured ? "background" : "default"}
          class={project.featured ? "md:col-span-3 h-[500px]" : ""}
        >
          {project.featured && project.images.length > 0 && (
              <div
                data-slideshow
                data-slide-count={project.images.length}
                slot='background'
                class='w-full h-full'
              >
                {project.images.map((img, i) => (
                  <Image
                    src={img}
                    alt={`${project.title} screenshot ${i + 1}`}
                    data-slide-img
                    class:list={[
                      "slideshow-img w-full h-full object-cover transition-transform duration-300 group-hover:scale-105",
                      { "opacity-100": i === 0, "opacity-0": i !== 0 },
                    ]}
                  />
                ))}
              </div>
          )}
          {project.featured && (
              <div class='flex flex-col justify-end h-full p-6 gap-2'>
                <div class='flex items-center gap-2'>
                  <h3 class='text-2xl font-semibold text-white'>{project.title}</h3>
                  {project.status === "in-progress" && (
                    <div class='flex items-center gap-2 pt-1'>
                      <span class='relative flex h-2 w-2'>
                          <span
                          class="absolute inline-flex h-full w-full rounded-full opacity-75 bg-yellow-400 animate-ping"
                          />
                          <span
                          class="relative inline-flex rounded-full h-2 w-2 bg-yellow-500"
                          />
                      </span>
                      <span class="text-xs text-yellow-300">In Progress</span>
                    </div>
                  )}
                </div>
                <p class='text-slate-200 max-w-xl'>{project.description}</p>
                <div class='flex flex-wrap gap-2 mb-4'>
                  {project.tags.map((tag) => (
                    <Tag class='bg-white/10 text-white'>{tag}</Tag>
                  ))}
                </div>
                <div class='flex items-center gap-4 flex-wrap'>
                  {project.liveUrl && (
                    <Button
                      href={project.liveUrl}
                      variant='primary'
                      target='_blank'
                      rel='noopener noreferrer'
                      class='group/button flex-shrink-0'
                    >
                      Project
                      <Icon
                        name='external-link'
                        slot='icon'
                        class='group-hover/button:translate-x-1 transition-transform duration-200'
                      />
                    </Button>
                  )}
                  <Button
                    href={project.githubUrl}
                    variant={project.liveUrl ? "ghost" : "primary"}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='text-white hover:text-slate-800 dark:hover:text-indigo-800 group/button flex-shrink-0'
                  >
                    Code
                    <Icon
                        name='external-link'
                        slot='icon'
                        class='group-hover/button:translate-x-1 transition-transform duration-200'
                      />
                  </Button>
                  {project.images.length > 1 && (
                    <div class='flex gap-1.5 ml-auto' data-slideshow-dots>
                      {project.images.map((_, i) => (
                        <button
                          data-slide-dot={i}
                          class:list={[
                            "w-2 h-2 rounded-full transition-colors duration-300 cursor-pointer",
                            { "bg-white": i === 0, "bg-white/40 hover:bg-white/60": i !== 0 },
                          ]}
                          aria-label={`Go to image ${i + 1}`}
                        />
                      ))}
                    </div>
                  )}
                </div>
              </div>
          )}
          {!project.featured && project.images.length > 0 && (
              <div
                data-slideshow
                data-slide-count={project.images.length}
                class='relative h-60 overflow-hidden'
              >
                {project.images.map((img, i) => (
                  <Image
                    src={img}
                    alt={`${project.title} screenshot ${i + 1}`}
                    data-slide-img
                    class:list={[
                      "slideshow-img w-full h-60 object-cover",
                      { "opacity-100": i === 0, "opacity-0": i !== 0 },
                    ]}
                  />
                ))}
                {project.images.length > 1 && (
                  <div class='absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5 z-10' data-slideshow-dots>
                    {project.images.map((_, i) => (
                      <button
                        data-slide-dot={i}
                        class:list={[
                          "w-2 h-2 rounded-full transition-colors duration-300 cursor-pointer shadow-sm",
                          { "bg-white": i === 0, "bg-white/40 hover:bg-white/60": i !== 0 },
                        ]}
                        aria-label={`Go to image ${i + 1}`}
                      />
                    ))}
                  </div>
                )}
              </div>
          )}
          {!project.featured && (
              <div class='p-6 flex gap-2 flex-col items-between'>
                <div class='flex items-between gap-2 '>
                  <h3 class='text-xl font-semibold'>{project.title}</h3>
                  {project.status === "in-progress" && (
                    <div class='flex items-center gap-2 pt-1'>
                      <span class='relative flex h-2 w-2'>
                          <span
                          class="absolute inline-flex h-full w-full rounded-full opacity-75 bg-yellow-400 animate-ping  "
                          />
                          <span
                          class="relative inline-flex rounded-full h-2 w-2 bg-yellow-500"
                          />
                      </span>
                      <span class="text-xs text-yellow-300">In Progress</span>
                    </div>
                  )}
                </div>
                <p class='text-slate-600 dark:text-slate-400'>{project.description}</p>
                <div class='flex flex-wrap gap-2 mb-4'>
                  {project.tags.map((tag) => (
                    <Tag>{tag}</Tag>
                  ))}
                </div>
                <div class='flex gap-x-4 flex-wrap'>
                  {project.liveUrl && (
                    <Button
                      href={project.liveUrl}
                      variant='primary'
                      target='_blank'
                      rel='noopener noreferrer'
                      class='group/button flex-shrink-0'
                    >
                      Project
                      <Icon
                        name='external-link'
                        slot='icon'
                        class='group-hover/button:translate-x-1 transition-transform duration-200'
                      />
                    </Button>
                  )}
                  <Button
                    href={project.githubUrl}
                    variant={project.liveUrl ? "ghost" : "primary"}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='group/button flex-shrink-0'
                  >
                    Code
                    <Icon
                        name='external-link'
                        slot='icon'
                        class='group-hover/button:translate-x-1 transition-transform duration-200'
                      />
                  </Button>
                </div>
              </div>
          )}
        </Card>
      ))
    }
  </div>
</section>

<style>
  .slideshow-img {
    position: absolute;
    inset: 0;
    transition: opacity 700ms ease-in-out;
  }
</style>

<script>
  function initSlideshows() {
    document.querySelectorAll<HTMLElement>("[data-slideshow]").forEach(function (container) {
      const count = parseInt(container.dataset.slideCount || "0", 10);
      if (count <= 1) return;

      const images = container.querySelectorAll<HTMLElement>("[data-slide-img]");
      const dotsContainer =
        container.querySelector("[data-slideshow-dots]") ||
        container.closest("article")?.querySelector("[data-slideshow-dots]");
      const dots = dotsContainer
        ? dotsContainer.querySelectorAll<HTMLButtonElement>("[data-slide-dot]")
        : [];

      let active = 0;
      let paused = false;

      function goTo(index: number) {
        images.forEach(function (img, i) {
          img.classList.toggle("opacity-100", i === index);
          img.classList.toggle("opacity-0", i !== index);
        });
        dots.forEach(function (dot, i) {
          dot.classList.toggle("bg-white", i === index);
          dot.classList.toggle("bg-white/40", i !== index);
          dot.classList.toggle("hover:bg-white/60", i !== index);
        });
        active = index;
      }

      const intervalId = setInterval(function () {
        if (paused) return;
        goTo((active + 1) % count);
      }, 4000);

      dots.forEach(function (dot) {
        dot.addEventListener("click", function () {
          const targetIndex = parseInt(dot.dataset.slideDot || "0", 10);
          if (targetIndex === active) {
            paused = !paused;
            return;
          }
          paused = true;
          goTo(targetIndex);
        });
      });

      container.dataset.intervalId = String(intervalId);
    });
  }

  initSlideshows();
</script>
