---
interface Props {
  id?: string;
  href?: string;
  variant?: "primary" | "secondary" | "outline" | "icon" | "ghost";
  target?: string;
  rel?: string;
  class?: string;
}

const { href, id, variant = "primary", target, rel, class: className = "" } = Astro.props;

const baseStyles =
  "inline-flex items-center justify-center rounded-full font-body font-medium transition-all duration-200 gap-2 cursor-pointer";

const variants = {
  primary:
    "bg-[var(--btn-primary-bg)] text-[var(--btn-primary-text)] hover:bg-[var(--btn-primary-bg-hover)] active:scale-95 focus:outline-none focus:ring-2 focus:ring-white/20 text-sm px-5 py-2.5",
  secondary:
    "text-text-primary bg-transparent border border-border hover:border-border-hover hover:bg-surface-2 focus:outline-none focus:ring-2 focus:ring-border text-sm px-5 py-2.5",
  outline:
    "h-10 px-4 border border-accent text-accent hover:bg-accent/10 focus:ring-2 focus:ring-accent/30",
  icon: "text-text-secondary hover:text-text-primary bg-transparent hover:bg-surface border border-transparent hover:border-border focus:ring-2 focus:ring-border focus:outline-none rounded-lg text-lg p-2.5 h-10 w-10 transition-all duration-150",
  ghost:
    "h-10 px-4 text-text-secondary hover:text-text-primary hover:bg-surface-2 focus:ring-2 focus:ring-border/50 rounded-lg",
};
---

{
  href ? (
    <a
      id={id}
      href={href}
      target={target}
      rel={rel}
      class:list={[baseStyles, variants[variant], className]}
    >
      <slot />
      {variant !== "icon" && <slot name='icon' />}
    </a>
  ) : (
    <button id={id} class:list={[baseStyles, variants[variant], className]}>
      <slot />
      {variant !== "icon" && <slot name='icon' />}
    </button>
  )
}
