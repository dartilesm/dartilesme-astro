---
interface Props {
  class?: string;
  variant?: "default" | "background";
}

const { class: className = "", variant = "default" } = Astro.props;
---

{
  variant === "default" ? (
    <article
      class:list={["bg-surface rounded-xl border border-border hover:border-border-hover transition-colors duration-200 overflow-hidden", className]}
    >
      <slot />
    </article>
  ) : (
    <article class:list={["relative rounded-xl overflow-hidden group border border-border hover:border-border-hover transition-colors duration-200", className]}>
      <div class='absolute inset-0 bg-gradient-to-b from-transparent via-black/60 to-black/90 z-10' />
      <div class='absolute inset-0'>
        <slot name='background' />
      </div>
      <div class='relative h-full z-20'>
        <slot />
      </div>
    </article>
  )
}
